@{

    Layout = null;

    var role = Context.Session.GetString("Role");

    @model List<PostEntry>
}

<!DOCTYPE html>

<html>


<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] CEC Announcements-Dashboard</title>

    <!--<link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />-->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/CEC_website.styles.css" asp-append-version="true" />
    <link rel="icon" href="~/Icon/Cebu_Eastern_College_Logo.png" asp-append-version="true" />
</head>

<body>
    <header>
        <nav>
            <div class="dashboard-navbar">

                <div class="dashboard-buttons">

                    <a class="logout-btn" asp-area="" asp-controller="Dashboard" asp-action="Logout">Logout</a>

                    @if (role == "Admin")
                    {
                        <a class="logout-btn" asp-area="" asp-controller="Dashboard" asp-action="Index">Dashbaord</a>

                    }

                </div>

                <h1 class="dashboard-name">CEBU EASTERN COLLEGE ANNOUNCEMENTS</h1>

            </div>
        </nav>
    </header>


    <main class="content">

        <div>
            <table class="Create-table">

                <thead>
                    <tr>
                        <th>Title</th>
                        <th>Content</th>
                        <th>Images</th>
                        <th>DayPosted</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>

                    <!--kani diri para na HttGet didto sa data base using model PostEntry-->
                         @foreach (var entry in Model)
                           {
                                   <tr>
                                       <td>@entry.Title</td>
                                       <td>@entry.Content</td>
                                       <td>@entry.ImagePath</td>
                                       <td>@entry.DayPosted</td>
                                       <td>Edit and Delete</td>
                                   </tr>
                           }
                   


                </tbody>






            </table>
        </div>



    </main>


    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

</body>



</html>