@{

    Layout = null;

    var role = Context.Session.GetString("Role");

    @model List<PostEntry>
}

<!DOCTYPE html> 

    <html>
    

        <head>
            <meta charset="utf-8" />
            <meta name="viewport" content="width=device-width, initial-scale=1.0" />
            
            <title>@ViewData["Title"] CEC Announcements-Dashboard</title>

           <!-- <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />-->
            <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
            <link rel="stylesheet" href="~/CEC_website.styles.css" asp-append-version="true" />
            <link rel="icon" href="~/Icon/Cebu_Eastern_College_Logo.png" asp-append-version="true" />
        </head>

        <body>
            <header>
                    <nav>
                        <div class="dashboard-navbar">
                            
                                 <div class="dashboard-buttons">

                                      <a class="logout-btn" asp-area="" asp-controller="Dashboard" asp-action="Logout">Logout</a>

                                          @if( role == "Admin")
                                              {
                                                   <a class="logout-btn" asp-area="" asp-controller="Dashboard" asp-action="Create">Create</a>

                                              }     
                                              
                                 </div>

                            <h1 class="dashboard-name">CEBU EASTERN COLLEGE ANNOUNCEMENTS</h1>

                        </div> 
                    </nav>
            </header>
           
          
             <main class="content">
                    
                    
                          <div class="index-container">

                              @foreach (var post in Model)
                              {
                                  <div class="index-card">

                                      <div class="index-header">
                                          <h3>@post.Title</h3>
                                          <small>@post.DayPosted</small>
                                      </div>

                                      <div class="index-content">

                                          <p>@Html.Raw(post.Content)</p>

                                          @if (!string.IsNullOrEmpty(post.ImagePath))
                                          {
                                              <img src="@post.ImagePath" class="index-image" />
                                          }
                                      </div>

                                      @if (Context.Session.GetString("Role") == "Admin")
                                      {
                                          <div class="index-actions">
                                              <a asp-action="Edit" asp-route-id="@post.Id">Edit</a>
                                              <a asp-action="Delete" asp-route-id="@post.Id">Delete</a>
                                          </div>
                                      }

                                  </div>
                              }

                          </div>
            </main>


           <script src="~/lib/jquery/dist/jquery.min.js"></script>
           <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
           <script src="~/js/site.js" asp-append-version="true"></script>
           <script src="~/js/edit.js" asp-append-version="true"></script>  

        </body>



    </html>